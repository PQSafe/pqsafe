# PQSafe API Reference — environment variables
# Copy to .env and fill in real values. Never commit .env to git.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=["*"]

# ---------------------------------------------------------------------------
# API authentication
# ---------------------------------------------------------------------------
# Bearer token required on write endpoints. Leave empty to disable (local dev only).
PQSAFE_API_KEY=

# ---------------------------------------------------------------------------
# Airwallex rail
# ---------------------------------------------------------------------------
# Get these from https://portal.airwallex.com → Developers → API Keys
AIRWALLEX_CLIENT_ID=your_client_id_here
AIRWALLEX_API_KEY=your_api_key_here
# 'sandbox' uses api-demo.airwallex.com  |  'prod' uses api.airwallex.com
AIRWALLEX_MODE=sandbox

# ---------------------------------------------------------------------------
# Twilio — SMS OTP (Verify V2)
# ---------------------------------------------------------------------------
# Account SID and Verify Service SID are pre-filled (non-secret).
# Only TWILIO_AUTH_TOKEN is secret — store in .env, never commit.
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid_here

# ---------------------------------------------------------------------------
# Mock / testing
# ---------------------------------------------------------------------------
# Set to 'true' to skip all real HTTP calls (auto-enabled when creds are absent)
PQSAFE_MOCK_MODE=false
