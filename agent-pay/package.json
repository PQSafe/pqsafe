{
  "name": "@pqsafe/agent-pay",
  "version": "0.1.0",
  "description": "PQ-signed spend envelopes for AI agent payments across multiple rails",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch --noEmit",
    "demo": "tsx examples/agentpay_demo.ts",
    "demo:claude": "tsx examples/claude_agent_demo.ts",
    "demo:claude-code": "tsx examples/claude_code_payment.ts",
    "demo:basic": "tsx examples/basic.ts",
    "test": "tsx tests/envelope.test.ts",
    "test:canonical": "tsx tests/canonicalization.test.ts",
    "test:sprint2": "tsx tests/sprint2_errors.test.ts",
    "test:adapters": "tsx tests/adapters.test.ts",
    "test:rails:wise": "tsx tests/rails/wise.test.ts",
    "test:rails:stripe": "tsx tests/rails/stripe.test.ts",
    "test:rails:usdc": "tsx tests/rails/usdc_base.test.ts",
    "test:rails:x402": "tsx tests/rails/x402.test.ts",
    "test:rails:router": "tsx tests/rails/selectRail.test.ts",
    "test:rails": "npm run test:rails:wise && npm run test:rails:stripe && npm run test:rails:usdc && npm run test:rails:x402 && npm run test:rails:router",
    "test:all": "npm test && npm run test:canonical && npm run test:sprint2 && npm run test:adapters && npm run test:rails"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@noble/post-quantum": "^0.6.0",
    "canonicalize": "^3.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@types/node": "^25.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PQSafe/pqsafe.git",
    "directory": "agent-pay"
  },
  "homepage": "https://pqsafe.xyz",
  "keywords": [
    "post-quantum",
    "ml-dsa",
    "ai-agent",
    "payments",
    "spend-envelope",
    "airwallex",
    "fips-204"
  ],
  "publishConfig": {
    "access": "public"
  }
}
