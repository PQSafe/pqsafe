{
  "name": "@pqsafe/agent-pay",
  "version": "0.1.0",
  "description": "PQ-signed spend envelopes for AI agent payments across multiple rails",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch --noEmit",
    "demo": "tsx examples/agentpay_demo.ts",
    "demo:claude": "tsx examples/claude_agent_demo.ts",
    "demo:claude-code": "tsx examples/claude_code_payment.ts",
    "demo:basic": "tsx examples/basic.ts",
    "demo:wise": "tsx demo/wise-sandbox-demo.ts",
    "demo:stripe": "tsx demo/stripe-sandbox-demo.ts",
    "demo:usdc": "tsx demo/usdc-sepolia-demo.ts",
    "demo:x402": "tsx demo/x402-demo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@noble/post-quantum": "^0.6.0",
    "canonicalize": "^3.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "fast-check": "^4.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  },
  "author": {
    "name": "PQSafe",
    "email": "dev@pqsafe.xyz",
    "url": "https://pqsafe.xyz"
  },
  "bugs": {
    "url": "https://github.com/PQSafe/pqsafe/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/PQSafe/pqsafe.git",
    "directory": "agent-pay"
  },
  "homepage": "https://pqsafe.xyz",
  "keywords": [
    "post-quantum",
    "ml-dsa",
    "ai-agent",
    "payments",
    "spend-envelope",
    "airwallex",
    "fips-204"
  ],
  "bin": {
    "pqsafe-admin": "./dist/cli/admin.js"
  },
  "publishConfig": {
    "access": "public"
  }
}
