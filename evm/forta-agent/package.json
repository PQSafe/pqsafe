{
  "name": "pqsafe-registry-forta-agent",
  "version": "0.1.0",
  "description": "Forta agent monitoring SpendEnvelopeRegistryV2_1 for circuit-breaker conditions",
  "main": "dist/agent.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && forta-agent run",
    "test": "jest --runInBand --forceExit",
    "lint": "eslint src --ext .ts",
    "push": "forta-agent push",
    "publish": "forta-agent publish"
  },
  "dependencies": {
    "@forta/agent": "^0.1.46",
    "ethers": "^5.7.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.5.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.spec.ts"],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.json"
      }
    }
  }
}
