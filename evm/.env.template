# PQSafe EVM — Arbitrum Sepolia Deploy Template
# -----------------------------------------------
# Copy this file to .env, fill in real values, then run the deploy command.
# NEVER commit .env to git. It is already in .gitignore.
#
# One-command deploy (after filling all 4 vars):
#   cd ~/Projects/pqsafe/evm
#   source .env && ~/.foundry/bin/forge script script/DeployV2_1_Sepolia.s.sol \
#     --rpc-url $ARB_SEPOLIA_RPC \
#     --private-key $TESTNET_KEY \
#     --broadcast \
#     --verify \
#     --etherscan-api-key $ETHERSCAN_API_KEY

# 1. TESTNET_KEY — Deployer wallet private key (TESTNET ONLY, never a mainnet key)
#    How to get: MetaMask → Account → ⋮ → Account Details → Show Private Key
#    Format: 0x followed by 64 hex characters
TESTNET_KEY=0x

# 2. ARB_SEPOLIA_RPC — Arbitrum Sepolia JSON-RPC endpoint
#    Free public endpoint (no signup): https://sepolia-rollup.arbitrum.io/rpc
#    Or Alchemy (faster, more reliable): https://dashboard.alchemy.com → Create App → Arbitrum Sepolia
ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# 3. ETHERSCAN_API_KEY — Arbiscan API key for source verification
#    Get free key: https://arbiscan.io/myapikey (sign up at arbiscan.io → API Keys)
ETHERSCAN_API_KEY=

# 4. ADMIN_ADDRESS — Wallet address that receives DEFAULT_ADMIN_ROLE on the deployed contract
#    Use the same wallet as TESTNET_KEY (MetaMask → copy the 0x address)
#    This address controls role grants post-deploy.
ADMIN_ADDRESS=0x

# -----------------------------------------------
# WALLET FUNDING — REQUIRED BEFORE DEPLOY
# -----------------------------------------------
# The TESTNET_KEY wallet must hold Arbitrum Sepolia ETH (free testnet tokens).
# Faucets (pick one, they're free):
#   - https://faucet.quicknode.com/arbitrum/sepolia
#   - https://www.alchemy.com/faucets/arbitrum-sepolia
#   - https://sepoliafaucet.com  (Ethereum Sepolia → bridge to Arb Sepolia via https://bridge.arbitrum.io)
# Typical deploy cost: ~0.001–0.005 ARB Sepolia ETH. Request 0.1 ETH to be safe.
# -----------------------------------------------

# Optional: separate issuer/pauser addresses (defaults to ADMIN_ADDRESS / hardcoded fallback if unset)
# TEST_ISSUER_ADDRESS=0x
# TEST_PAUSER_ADDRESS=0x
