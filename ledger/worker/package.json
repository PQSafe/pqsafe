{
  "name": "pqsafe-ledger-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply pqsafe-ledger --local",
    "db:migrate:remote": "wrangler d1 migrations apply pqsafe-ledger --remote",
    "db:seed:local": "wrangler d1 execute pqsafe-ledger --local --file=../migrations/0001_init.sql",
    "db:seed:remote": "wrangler d1 execute pqsafe-ledger --remote --file=../migrations/0001_init.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.78.0"
  }
}
